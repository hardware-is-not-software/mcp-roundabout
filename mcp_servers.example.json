{
  "mcpServers": {
    "memory": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "sqlite": {
        "command": "uvx",
        "args": ["mcp-server-sqlite", "--db-path", "test.db"]
    },
    "docker-example": {
        "command": "docker",
        "args": [
            "run",
            "--rm",
            "-i",
            "node:20-alpine",
            "npx",
            "-y",
            "@modelcontextprotocol/server-memory"
        ]
    },
    "deepwiki": {
        "url": "https://mcp.deepwiki.com/mcp"
    }
  }
}
